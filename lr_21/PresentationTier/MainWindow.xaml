<Window x:Class="PresentationTier.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Height="450"
        Width="500">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Автомобили в наличии">
            <ListBox ItemsSource="{Binding Cars}"
                     DisplayMemberPath="FullTitle"/>
        </GroupBox>

        <StackPanel Grid.Row="1"
                    Margin="0,15">
            <TextBlock Text="Общая стоимость автопарка:"/>
            <TextBlock Text="{Binding TotalStockValue, StringFormat={}{0:N2} руб.}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="DarkBlue"/>
        </StackPanel>

        <GroupBox Header="Средняя цена по брендам"
                  Grid.Row="2">
            <ItemsControl ItemsSource="{Binding AveragePriceByBrand}"/>
        </GroupBox>
    </Grid>
</Window>